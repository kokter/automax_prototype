# ─────────────────────────────────────────────────────────────────────────
# Пример конфигурации сервиса. Скопируйте в .env и при необходимости измените:
#     cp .env.example .env
# Файл .env содержит реальные настройки и НЕ коммитится в репозиторий.
# ─────────────────────────────────────────────────────────────────────────

# Адрес Qdrant. Docker (по умолчанию) — http://localhost:6333.
# Для быстрых тестов без Docker можно указать :memory:
QDRANT_URL=http://localhost:6333

# Embedding-модель и размерность её вектора.
# bge-m3 -> 1024. При смене модели поменяйте и VECTOR_SIZE.
EMBED_MODEL=BAAI/bge-m3
VECTOR_SIZE=1024

# API-ключи арендаторов: "ключ:арендатор" через запятую (мультитенантность).
# В продакшене замените демо-ключи на свои.
API_KEYS=demo-key-automax:automax,demo-key-second:second_shop

# Сколько кандидатов брать из каждого движка перед объединением RRF.
CANDIDATES=20

# Константа сглаживания RRF.
RRF_K=60

# Тестовый режим без нейромодели: 1 — псевдо-векторы (только smoke-тест), 0 — bge-m3.
PROTOTYPE_FAKE_EMBED=0
